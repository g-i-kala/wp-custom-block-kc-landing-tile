{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "create-block/kc-landing-tile",
  "version": "0.1.0",
  "title": "Kc Landing Tile",
  "category": "widgets",
  "icon": "smiley",
  "description": "Example block scaffolded with Create Block tool.",
  "example": {},
  "supports": {
    "html": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "source": "html",
      "selector": ".kc-tile__title",
      "default": "Tile title"
    },
    "url": {
      "type": "string",
      "default": ""
    },
    "mediaUrl": {
      "type": "string",
      "default": ""
    },
    "mediaId": {
      "type": "number"
    },
    "overlayColor": {
      "type": "string",
      "default": "#000000"
    },
    "overlayOpacity": {
      "type": "number",
      "default": 0.45
    },
    "hoverZoom": {
      "type": "number",
      "default": 1.08
    },
    "shadow": {
      "type": "boolean",
      "default": true
    }
  },
  "textdomain": "kc-landing-tile",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js"
}